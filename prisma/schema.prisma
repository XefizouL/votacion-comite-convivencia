generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Módulo de Convocatoria
model Convocation {
  id           String   @id @default(uuid())
  title        String
  openDate     DateTime
  closeDate    DateTime
  requirements String
  reglamentUrl String?
  createdAt    DateTime @default(now())
}

// Módulo de Registro (Funcionarios)
model User {
  id          String   @id @default(uuid())
  fullName    String
  documentId  String   @unique
  email       String   @unique

  role        Role     @default(VOTER)
  hasVoted    Boolean  @default(false)
  vote        Vote?
  createdAt   DateTime @default(now())
}

enum Role {
  VOTER
  ADMIN
}

// Módulo de Postulación de Candidatos
model Candidate {
  id          String          @id @default(uuid())
  fullName    String
  position    String
 
  photoUrl    String
  status      CandidateStatus @default(PENDING)
  votes       Vote[]
  createdAt   DateTime        @default(now())
}

enum CandidateStatus {
  PENDING
  APPROVED
  REJECTED
}

// Módulo de Votación
model Vote {
  id          String    @id @default(uuid())
  user        User      @relation(fields: [userId], references: [id])
  userId      String    @unique
  candidate   Candidate @relation(fields: [candidateId], references: [id])
  candidateId String
  createdAt   DateTime  @default(now())
}